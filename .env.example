# Optional AI providers. The app works without these by using a local explanatory fallback.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview

# Optional market data key. Free/no-key Yahoo-style public data is the default.
MARKET_DATA_PROVIDER=yahoo
# MARKET_DATA_PROVIDER=alpha_vantage
ALPHA_VANTAGE_API_KEY=

# Optional realtime seconds candles. Required for 1s/5s/15s candles, Time & Sales, and bid/ask spread.
REALTIME_DATA_PROVIDER=polygon
POLYGON_API_KEY=

# Optional delayed public short-flow files. These are plain public file URLs, not secrets.
# Leave blank to show source links and unavailable warnings in the app.
FINRA_SHORT_INTEREST_CSV_URL=
FINRA_SHORT_VOLUME_CSV_URL=
SEC_FTD_TXT_URL=
CBOE_PUT_CALL_RATIO_CSV_URL=
